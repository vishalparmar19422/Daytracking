PORT=5000
# Postgres connection string. For Neon, copy the "Connection string" from your
# project dashboard (use the pooled one, sslmode=require).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Secret used to sign login tokens. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string
# Set to false to disable the POST /api/dev/seed demo-data endpoint.
ALLOW_DEV_SEED=true
